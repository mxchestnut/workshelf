# Terraform state and temporary files
.terraform/
*.tfstate
*.tfstate.*
.terraform.lock.hcl

# Variable files with secrets
terraform.tfvars
*.auto.tfvars
*.tfvars.json

# Crash log files
crash.log
crash.*.log

# Ignore override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore CLI configuration files
.terraformrc
terraform.rc
