# Docker Development Environment Variables
# Copy this file to .env and update with your own values
# NEVER commit the .env file to version control

# PostgreSQL Database
POSTGRES_DB=workshelf
POSTGRES_USER=workshelf
POSTGRES_PASSWORD=change_this_password_for_local_dev

# Keycloak Authentication
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=change_this_admin_password
KC_DB_USERNAME=workshelf
KC_DB_PASSWORD=change_this_password_for_local_dev

# MinIO Object Storage
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_this_minio_password

# Backend Application
DATABASE_URL=postgresql+asyncpg://workshelf:change_this_password_for_local_dev@postgres:5432/workshelf
SECRET_KEY=change_this_secret_key_for_local_dev
KEYCLOAK_SERVER_URL=http://keycloak:8080

# AI Services (optional for local development)
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-4-sonnet-20250514

# Stripe Payment Processing (optional for local development)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Content Integrity (optional for local development)
GPTZERO_API_KEY=
COPYSCAPE_API_KEY=
COPYSCAPE_USERNAME=
